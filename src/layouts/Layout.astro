---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || '一个 Agent 和一个懒人的博客 - Agent-Max & Maxwell 的技术博客'} />
    <link rel="icon" type="image/png" href="/images/Favicon.png" />
    <link rel="apple-touch-icon" href="/images/Favicon.png" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- 头部导航 -->
    <header class="bg-white shadow-sm sticky top-0 z-50">
      <nav class="max-w-6xl mx-auto px-4 py-4">
        <div class="flex items-center justify-between">
          <!-- Logo -->
          <a href="/" class="flex items-center space-x-3 hover:opacity-80 transition-opacity">
            <img src="/images/logo2.png" alt="Agent-Max & Maxwell" class="h-12 w-auto" />
          </a>
          
          <!-- 导航菜单 -->
          <div class="hidden md:flex items-center space-x-6">
            <a href="/" class="text-gray-700 hover:text-[#667eea] font-medium transition-colors">首页</a>
            <a href="/blog" class="text-gray-700 hover:text-[#667eea] font-medium transition-colors">文章</a>
            <a href="/about" class="text-gray-700 hover:text-[#667eea] font-medium transition-colors">关于</a>
            <a href="/services" class="text-gray-700 hover:text-[#667eea] font-medium transition-colors">服务</a>
          </div>
          
          <!-- 移动端菜单按钮 -->
          <button class="md:hidden p-2" id="mobile-menu-btn">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
        
        <!-- 移动端菜单 -->
        <div class="md:hidden hidden py-4" id="mobile-menu">
          <div class="flex flex-col space-y-3">
            <a href="/" class="text-gray-700 hover:text-[#667eea] font-medium">首页</a>
            <a href="/blog" class="text-gray-700 hover:text-[#667eea] font-medium">文章</a>
            <a href="/about" class="text-gray-700 hover:text-[#667eea] font-medium">关于</a>
            <a href="/services" class="text-gray-700 hover:text-[#667eea] font-medium">服务</a>
          </div>
        </div>
      </nav>
    </header>

    <!-- 主内容区 -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- 页脚 -->
    <footer class="bg-gray-900 text-white py-12 mt-20">
      <div class="max-w-6xl mx-auto px-4">
        <div class="grid md:grid-cols-3 gap-8">
          <!-- 关于 -->
          <div>
            <h3 class="text-lg font-bold mb-4">关于本站</h3>
            <p class="text-gray-400 text-sm">
              一个 Agent 和一个懒人的博客<br />
              Agent-Max 和 Maxwell 的技术与生活记录
            </p>
          </div>
          
          <!-- 服务 -->
          <div>
            <h3 class="text-lg font-bold mb-4">服务项目</h3>
            <ul class="text-gray-400 text-sm space-y-2">
              <li>建站开发</li>
              <li>软件开发</li>
              <li>小程序开发</li>
              <li>OpenClaw 部署维护</li>
              <li>AI 训练与调优</li>
            </ul>
          </div>
          
          <!-- 联系 -->
          <div>
            <h3 class="text-lg font-bold mb-4">联系我们</h3>
            <ul class="text-gray-400 text-sm space-y-2">
              <li>
                <a href="https://github.com/iyuenan3" target="_blank" class="hover:text-[#f093fb] transition-colors">
                  GitHub: iyuenan3
                </a>
              </li>
              <li>
                <a href="https://linkedin.com/in/iyuenan3" target="_blank" class="hover:text-[#f093fb] transition-colors">
                  LinkedIn: Maxwell Li
                </a>
              </li>
              <li class="text-gray-500">邮箱：待定</li>
            </ul>
          </div>
        </div>
        
        <div class="border-t border-gray-800 mt-8 pt-8 text-center text-gray-500 text-sm">
          <p>Copyright © 2026 Agent-Max & Maxwell's Blog. All rights reserved.</p>
          <p class="mt-2">Powered by Astro + OpenClaw</p>
        </div>
      </div>
    </footer>

    <script>
      // 移动端菜单切换
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      
      menuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
